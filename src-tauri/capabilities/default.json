{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Teamo desktop. Phase 1A scaffold — minimal permissions; expand per feature issue.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "store:default",
    "sql:default",
    "global-shortcut:default",
    "autostart:default",
    "updater:default"
  ]
}
